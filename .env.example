# ──────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT VARIABLES EXAMPLE
# ──────────────────────────────────────────────────────────────────────────────
# This file serves as a template for your local .env configuration.
# Copy this file to .env and fill in the actual values.
# ──────────────────────────────────────────────────────────────────────────────

# ─── APP SETTINGS ───
# Public URL of your application (e.g. https://yok-airline.vercel.app or http://localhost:3000)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment (development, production, or test)
NODE_ENV="development"

# ─── DATABASE (SQL/POSTGRESQL) ───
# Primary database for users, flights, aircraft, etc.
POSTGRES_USER="your_postgres_user"
POSTGRES_PASSWORD="your_postgres_password"
POSTGRES_DATABASE="airline_db"
POSTGRES_PORT=5432
DATABASE_URL="postgresql://user:password@localhost:5432/yok_airline?schema=public"

# ─── DATABASE (NOSQL/MONGODB) ───
# Database for Flight Operations Logs and high-frequency data
MONGO_INITDB_ROOT_USERNAME="root"
MONGO_INITDB_ROOT_PASSWORD="your_mongo_password"
MONGO_PORT=27017
MONGO_COMPASS_PORT=8081
MONGO_USER_DATABASE_URL="mongodb://root:password@localhost:27017/yok_logs?authSource=admin"
# MONGODB_URI="mongodb://localhost:27017/yok_logs" # Alternative name

# ─── PGADMIN ───
PGADMIN_DEFAULT_EMAIL="admin@example.com"
PGADMIN_DEFAULT_PASSWORD="your_pgadmin_password"
PGADMIN_PORT=8080

# ─── MONGO EXPRESS ───
MONGO_EXPRESS_USER="admin"
MONGO_EXPRESS_PASSWORD="your_mongo_express_password"

# ─── BETTER AUTH (AUTHENTICATION) ───
# A secret key used to sign session cookies (at least 32 characters)
BETTER_AUTH_SECRET="your-randomly-generated-auth-secret-key-32-chars"
# Explicit URL for Auth server (usually same as APP_URL)
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_BASE_URL="http://localhost:3000"

# ─── STRIPE (PAYMENTS) ───
# Public key from your Stripe Dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Secret key from your Stripe Dashboard
STRIPE_SECRET_KEY="sk_test_..."
# Webhook secret for local development (obtain via 'stripe listen')
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── MAPBOX (MAPS) ───
# Public token for rendering the Live Operation Map
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1Ijo..."

# ─── SEEDING (DEVELOPMENT) ───
# Default password for all seeded users (Admin, Pilots, Staff)
SEED_DEFAULT_PASSWORD="Passw0rd123!"