generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PASSENGER
  ADMIN
  CAPTAIN
  CREW
}

enum AircraftStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum FlightStatus {
  SCHEDULED
  BOARDING
  DELAYED
  DEPARTED
  ARRIVED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TicketClass {
  ECONOMY
  BUSINESS
  FIRST_CLASS
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model User {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
  email        String @unique
  role         Role   @default(PASSENGER)

  // Crew / Captain
  licenseNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
  flights  Flight[]  @relation("CaptainFlights")
}

model Airport {
  id       Int    @id @default(autoincrement())
  iataCode String @unique
  name     String
  city     String
  country  String

  origins      Route[] @relation("OriginAirport")
  destinations Route[] @relation("DestAirport")
}

model Route {
  id              Int  @id @default(autoincrement())
  originAirportId Int
  destAirportId   Int
  distanceKm      Int
  durationMins    Int?

  origin      Airport  @relation("OriginAirport", fields: [originAirportId], references: [id])
  destination Airport  @relation("DestAirport", fields: [destAirportId], references: [id])
  flights     Flight[]

  @@unique([originAirportId, destAirportId])
}

model AircraftType {
  id          Int    @id @default(autoincrement())
  iataCode    String @unique
  model       String
  capacityEco Int
  capacityBiz Int

  fleet Aircraft[]
}

model Aircraft {
  id         Int            @id @default(autoincrement())
  tailNumber String         @unique
  status     AircraftStatus @default(ACTIVE)

  aircraftTypeId Int
  type           AircraftType @relation(fields: [aircraftTypeId], references: [id])

  flights Flight[]
}

model Flight {
  id         Int     @id @default(autoincrement())
  flightCode String  @unique
  routeId    Int
  aircraftId Int
  captainId  Int
  gate       String?

  departureTime DateTime
  arrivalTime   DateTime
  status        FlightStatus @default(SCHEDULED)

  basePrice Decimal @db.Decimal(10, 2)

  route    Route     @relation(fields: [routeId], references: [id])
  aircraft Aircraft  @relation(fields: [aircraftId], references: [id])
  captain  User      @relation("CaptainFlights", fields: [captainId], references: [id])
  bookings Booking[]
}

model Booking {
  id         Int           @id @default(autoincrement())
  bookingRef String        @unique
  userId     Int
  flightId   Int
  status     BookingStatus @default(PENDING)
  totalPrice Decimal       @db.Decimal(10, 2)
  createdAt  DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id])
  flight       Flight        @relation(fields: [flightId], references: [id])
  tickets      Ticket[]
  transactions Transaction[]
}

model Ticket {
  id            Int         @id @default(autoincrement())
  bookingId     Int
  passengerName String
  seatNumber    String
  class         TicketClass @default(ECONOMY)
  price         Decimal     @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id])

  @@unique([bookingId, seatNumber])
}

model Transaction {
  id            Int               @id @default(autoincrement())
  bookingId     Int
  amount        Decimal           @db.Decimal(10, 2)
  status        TransactionStatus @default(PENDING)
  paymentMethod String

  stripeChargeId String?

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Country {
  code String @id
  name String

  // airports Airport[]
}
