// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PASSENGER
  ADMIN

  // Operational Staff
  PILOT
  CABIN_CREW
  GROUND_STAFF // Gate/Check-in
  MECHANIC
}

enum Rank {
  CAPTAIN
  FIRST_OFFICER
  PURSER
  CREW
  MANAGER
  SUPERVISOR
  STAFF
}

enum AircraftStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum FlightStatus {
  SCHEDULED
  BOARDING
  DELAYED
  DEPARTED
  ARRIVED
  CANCELLED
  DIVERTED
  EMERGENCY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TicketClass {
  ECONOMY
  BUSINESS
  FIRST_CLASS
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum EmergencyStatus {
  ACTIVE
  RESOLVED
  CLOSED
}

model User {
  id    String @id @default(cuid())
  email String @unique
  role  Role   @default(PASSENGER)

  firstName String?
  lastName  String?
  phone     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings       Booking[]
  staffProfile   StaffProfile?
  completedTasks ActiveEmergencyTask[]
  name           String
  emailVerified  Boolean               @default(false)
  image          String?
  sessions       Session[]
  accounts       Account[]

  @@map("user")
}

model StaffProfile {
  id         String @id @default(cuid())
  userId     String @unique
  employeeId String @unique

  role Role
  rank Rank?

  // Operational Fields
  baseAirportId String?
  stationId     String?

  mongoProfileId String?

  user        User     @relation(fields: [userId], references: [id])
  baseAirport Airport? @relation("StaffBase", fields: [baseAirportId], references: [id])
  station     Airport? @relation("StaffStation", fields: [stationId], references: [id])

  pilotedFlights Flight[] @relation("CaptainFlights")
}

model Airport {
  id       String @id @default(cuid())
  iataCode String @unique // e.g. "BKK"
  name     String
  city     String
  country  String // Changed from countryCode to a simple string

  origins      Route[] @relation("OriginAirport")
  destinations Route[] @relation("DestAirport")

  basedStaff     StaffProfile[] @relation("StaffBase")
  stationedStaff StaffProfile[] @relation("StaffStation")
}

model AircraftType {
  id          String @id @default(cuid())
  iataCode    String @unique
  model       String
  capacityEco Int
  capacityBiz Int

  fleet Aircraft[]
}

model Aircraft {
  id         String         @id @default(cuid())
  tailNumber String         @unique
  status     AircraftStatus @default(ACTIVE)

  aircraftTypeId String
  type           AircraftType @relation(fields: [aircraftTypeId], references: [id])

  flights Flight[]
}

model Route {
  id              String @id @default(cuid())
  originAirportId String
  destAirportId   String
  distanceKm      Int
  durationMins    Int?

  origin      Airport  @relation("OriginAirport", fields: [originAirportId], references: [id])
  destination Airport  @relation("DestAirport", fields: [destAirportId], references: [id])
  flights     Flight[]

  @@unique([originAirportId, destAirportId])
}

model Flight {
  id         String @id @default(cuid())
  flightCode String @unique

  routeId    String
  aircraftId String
  captainId  String? // StaffProfile ID
  gate       String?

  departureTime DateTime
  arrivalTime   DateTime
  status        FlightStatus @default(SCHEDULED)
  basePrice     Decimal      @db.Decimal(10, 2)

  route    Route         @relation(fields: [routeId], references: [id])
  aircraft Aircraft      @relation(fields: [aircraftId], references: [id])
  captain  StaffProfile? @relation("CaptainFlights", fields: [captainId], references: [id])

  bookings  Booking[]
  incidents EmergencyIncident[]
}

model Booking {
  id         String @id @default(cuid())
  bookingRef String @unique // PNR 6 digits

  userId     String // Booker
  flightId   String
  status     BookingStatus @default(PENDING)
  totalPrice Decimal       @db.Decimal(10, 2)

  contactEmail String?
  contactPhone String?

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  flight       Flight        @relation(fields: [flightId], references: [id])
  tickets      Ticket[]
  transactions Transaction[]
}

model Ticket {
  id        String @id @default(cuid())
  bookingId String

  // Passenger Info
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  passportNumber String?
  gender         String?

  seatNumber String
  class      TicketClass @default(ECONOMY)
  price      Decimal     @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Transaction {
  id             String            @id @default(cuid())
  bookingId      String
  amount         Decimal           @db.Decimal(10, 2)
  status         TransactionStatus @default(PENDING)
  paymentMethod  String
  stripeChargeId String?
  createdAt      DateTime          @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}

model EmergencyType {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  templates EmergencyTaskTemplate[]
  incidents EmergencyIncident[]
}

model EmergencyTaskTemplate {
  id              String @id @default(cuid())
  emergencyTypeId String
  role            Role
  description     String
  priority        Int

  emergencyType EmergencyType @relation(fields: [emergencyTypeId], references: [id])
}

model EmergencyIncident {
  id              String          @id @default(cuid())
  flightId        String
  emergencyTypeId String
  status          EmergencyStatus @default(ACTIVE)
  declaredAt      DateTime        @default(now())
  resolvedAt      DateTime?

  flight Flight        @relation(fields: [flightId], references: [id])
  type   EmergencyType @relation(fields: [emergencyTypeId], references: [id])

  tasks ActiveEmergencyTask[]
}

model ActiveEmergencyTask {
  id           String @id @default(cuid())
  incidentId   String
  description  String
  assignedRole Role

  isCompleted       Boolean   @default(false)
  completedByUserId String?
  completedAt       DateTime?

  incident    EmergencyIncident @relation(fields: [incidentId], references: [id])
  completedBy User?             @relation(fields: [completedByUserId], references: [id])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
