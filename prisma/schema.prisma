generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PASSENGER
  ADMIN
  PILOT
  CABIN_CREW
  GROUND_STAFF
  MECHANIC
}

enum Rank {
  CAPTAIN
  FIRST_OFFICER
  PURSER
  CREW
  MANAGER
  SUPERVISOR
  STAFF
}

enum AircraftStatus {
  ACTIVE
  MAINTENANCE
  RETIRED
}

enum FlightStatus {
  SCHEDULED
  BOARDING
  DELAYED
  DEPARTED
  ARRIVED
  CANCELLED
  DIVERTED
  EMERGENCY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum TicketClass {
  ECONOMY
  BUSINESS
  FIRST_CLASS
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TransactionType {
  PAYMENT
  REFUND
}

enum CabinClass {
  FIRST
  BUSINESS
  ECONOMY
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  phone         String?
  image         String?
  emailVerified Boolean  @default(false)
  role          Role     @default(PASSENGER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mongoProfileId String? @unique

  sessions     Session[]
  accounts     Account[]
  staffProfile StaffProfile?
  bookings     Booking[]

  @@index([role])
  @@map("user")
}

model StaffProfile {
  id         String @id @default(cuid())
  userId     String @unique
  employeeId String @unique
  role       Role
  rank       Rank?

  baseAirportId String?
  stationId     String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseAirport Airport? @relation("StaffBase", fields: [baseAirportId], references: [id])
  station     Airport? @relation("StaffStation", fields: [stationId], references: [id])

  pilotedFlights Flight[] @relation("CaptainFlights")

  @@index([role])
  @@index([baseAirportId])
}

model Airport {
  id       String @id @default(cuid())
  iataCode String @unique
  name     String
  city     String
  country  String
  lat      Float
  lon      Float

  origins      Route[] @relation("OriginAirport")
  destinations Route[] @relation("DestAirport")

  basedStaff     StaffProfile[] @relation("StaffBase")
  stationedStaff StaffProfile[] @relation("StaffStation")
}

model AircraftType {
  id            String @id @default(cuid())
  iataCode      String @unique
  model         String
  capacityEco   Int
  capacityBiz   Int
  capacityFirst Int    @default(0)

  fleet      Aircraft[]
  seatLayout SeatLayoutTemplate?
}

model Aircraft {
  id             String         @id @default(cuid())
  tailNumber     String         @unique
  status         AircraftStatus @default(ACTIVE)
  aircraftTypeId String

  type    AircraftType @relation(fields: [aircraftTypeId], references: [id])
  flights Flight[]

  @@index([status])
}

model SeatLayoutTemplate {
  id             String  @id @default(cuid())
  aircraftTypeId String  @unique
  reference      String?

  aircraftType AircraftType      @relation(fields: [aircraftTypeId], references: [id], onDelete: Cascade)
  cabins       SeatLayoutCabin[]
}

model SeatLayoutCabin {
  id           String     @id @default(cuid())
  templateId   String
  cabin        CabinClass
  rowStart     Int
  rowEnd       Int
  columns      String[]
  aisleAfter   String[]
  exitRows     Int[]
  blockedSeats String[]
  sortOrder    Int        @default(0)

  template SeatLayoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Route {
  id              String @id @default(cuid())
  originAirportId String
  destAirportId   String
  distanceKm      Int
  durationMins    Int?

  origin      Airport  @relation("OriginAirport", fields: [originAirportId], references: [id])
  destination Airport  @relation("DestAirport", fields: [destAirportId], references: [id])
  flights     Flight[]

  @@unique([originAirportId, destAirportId])
}

model Flight {
  id         String       @id @default(cuid())
  flightCode String       @unique
  routeId    String
  aircraftId String
  captainId  String?
  gate       String?
  status     FlightStatus @default(SCHEDULED)

  departureTime DateTime
  arrivalTime   DateTime

  basePriceEconomy  Decimal @db.Decimal(10, 2)
  basePriceBusiness Decimal @db.Decimal(10, 2)
  basePriceFirst    Decimal @db.Decimal(10, 2)

  activeIncidentId String?

  route    Route         @relation(fields: [routeId], references: [id])
  aircraft Aircraft      @relation(fields: [aircraftId], references: [id])
  captain  StaffProfile? @relation("CaptainFlights", fields: [captainId], references: [id])

  bookings Booking[]
  tickets  Ticket[]  @relation("FlightTickets")

  @@index([status])
  @@index([departureTime])
  @@index([routeId])
}

model Booking {
  id         String        @id @default(cuid())
  bookingRef String        @unique
  userId     String
  flightId   String
  status     BookingStatus @default(PENDING)
  totalPrice Decimal       @db.Decimal(10, 2)
  currency   String        @default("THB")

  contactEmail String?
  contactPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  flight       Flight        @relation(fields: [flightId], references: [id])
  tickets      Ticket[]
  transactions Transaction[]

  @@index([userId])
  @@index([flightId])
  @@index([status])
}

model Ticket {
  id         String      @id @default(cuid())
  bookingId  String
  flightId   String
  class      TicketClass @default(ECONOMY)
  seatNumber String?
  price      Decimal     @db.Decimal(10, 2)

  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  passportNumber String?
  nationality    String?
  gender         String?

  checkedIn    Boolean   @default(false)
  checkedInAt  DateTime?
  boardingPass String?

  seatSurcharge Decimal @default(0) @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id])
  flight  Flight  @relation("FlightTickets", fields: [flightId], references: [id])

  @@unique([flightId, seatNumber])
  @@index([bookingId])
  @@index([flightId])
}

model Transaction {
  id        String            @id @default(cuid())
  bookingId String
  amount    Decimal           @db.Decimal(10, 2)
  currency  String            @default("THB")
  status    TransactionStatus @default(PENDING)
  type      TransactionType   @default(PAYMENT)

  paymentMethodType String?
  paymentMethodRef  String?

  stripePaymentIntentId String? @unique
  stripeChargeId        String?

  failureCode    String?
  failureMessage String?

  refundedAt            DateTime?
  refundReason          String?
  originalTransactionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
  @@index([stripePaymentIntentId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
